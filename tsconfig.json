{
  "compilerOptions": {
    /* Base Options */
    "target": "es5", /* Specify ECMAScript target version: 'ES3' (default), 'ES5', 'ES2015', 'ES2016', 'ES2017', 'ES2018', 'ES2019', 'ES2020', 'ES2021', 'ES2022', 'ESNext'. */
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ], /* Specify library files to be included in the compilation. */
    "allowJs": true, /* Allow javascript files to be compiled. */
    "skipLibCheck": true, /* Skip type checking of declaration files. */
    "strict": true, /* Enable all strict type-checking options. */
    "forceConsistentCasingInFileNames": true, /* Ensure that casing of paths in imports matches the file system's. */
    "noEmit": true, /* Do not emit outputs. */
    "esModuleInterop": true, /* Enables emit interoperability between CommonJS and ES Modules. */
    "module": "esnext", /* Specify module code generation: 'none', 'commonjs', 'amd', 'system', 'umd', 'es2015', 'es2020', 'es2022', 'esnext', 'node16', 'nodenext'. */
    "moduleResolution": "bundler", /* Specify module resolution strategy: 'node' (Node.js), 'classic' (TypeScript pre-1.6), 'bundler'. 'bundler' is recommended for App Router. */
    "resolveJsonModule": true, /* Enable importing .json files. */
    "isolatedModules": true, /* Ensure that each file can be safely transpiled without relying on other imports. */
    "jsx": "preserve", /* Specify JSX code generation: 'preserve', 'react-native', 'react', 'react-jsx', 'react-jsxdev'. */
    "incremental": true, /* Enable incremental compilation. */
    "plugins": [ /* List of language service plugins to include. */
      {
        "name": "next" /* Next.js TypeScript plugin. Essential for App Router features. */
      }
    ],
    "paths": { /* A series of entries which re-map imports to lookup locations relative to the 'baseUrl'. */
      "@/*": [
        "./*"
      ] /* Example: Allows absolute imports from your project root. */
    }
  },
  "include": [ /* Specify an array of filenames or patterns to include in the program. */
    "**/*.ts", /* Generated by Next.js, contains global types for Next.js environment. */
    "**/*.tsx", /* Include all TypeScript files. */
    "next-env.d.ts" /* Include all TypeScript React files. */,
    ".next/types/**/*.ts"
  ],
  "exclude": [ /* Specify an array of filenames or patterns that should be excluded from the program. */
    "node_modules" /* Standard exclusion. */
  ]
}
